+    // Rotate a flat RGB byte buffer 90° clockwise.
+    // srcW/srcH are the original dimensions; returned buffer has dims srcH × srcW.
+    static uint8_t* rotateBuffer90CW(const uint8_t* src, int srcW, int srcH) {
+        int dstW = srcH, dstH = srcW;
+        uint8_t* dst = (uint8_t*)malloc(dstW * dstH * 3);
+        for (int sy = 0; sy < srcH; sy++) {
+            for (int sx = 0; sx < srcW; sx++) {
+                int si = (sy * srcW + sx) * 3;
+                int dx = dstW - 1 - sy;
+                int dy = sx;
+                int di = (dy * dstW + dx) * 3;
+                dst[di]     = src[si];
+                dst[di + 1] = src[si + 1];
+                dst[di + 2] = src[si + 2];
+            }
+        }
+        return dst;
+    }
+
+    // Rotate a flat RGB byte buffer 270° clockwise (= 90° CCW).
+    // srcW/srcH are the original dimensions; returned buffer has dims srcH × srcW.
+    static uint8_t* rotateBuffer270CW(const uint8_t* src, int srcW, int srcH) {
+        int dstW = srcH, dstH = srcW;
+        uint8_t* dst = (uint8_t*)malloc(dstW * dstH * 3);
+        for (int sy = 0; sy < srcH; sy++) {
+            for (int sx = 0; sx < srcW; sx++) {
+                int si = (sy * srcW + sx) * 3;
+                int dx = sy;
+                int dy = dstH - 1 - sx;
+                int di = (dy * dstW + dx) * 3;
+                dst[di]     = src[si];
+                dst[di + 1] = src[si + 1];
+                dst[di + 2] = src[si + 2];
+            }
+        }
+        return dst;
+    }
